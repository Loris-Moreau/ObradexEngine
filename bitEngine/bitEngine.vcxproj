<?xml version="1.0" encoding="utf-8"?>
<!--
  bitEngine.vcxproj  —  Visual Studio 2022
  =========================================
  All engine source files live flat in bitEngine/ alongside this .vcxproj.
  Third-party libraries live in ..\third_party\ (one level up, in the solution root).

  BEFORE BUILDING: run setup.sh in Git Bash to populate third_party/
    bash setup.sh
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{2E6F2CAD-12C1-4A5F-A03E-767D91E14106}</ProjectGuid>
    <RootNamespace>bitEngine</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings" />
  <ImportGroup Label="Shared" />

  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"
            Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')"
            Label="LocalAppDataPlatform" />
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"
            Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')"
            Label="LocalAppDataPlatform" />
  </ImportGroup>

  <PropertyGroup Label="UserMacros" />

  <!-- ── Output paths ─────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <OutDir>$(SolutionDir)build\bin\Debug\</OutDir>
    <IntDir>$(SolutionDir)build\obj\Debug\bitEngine\</IntDir>
    <LinkIncremental>true</LinkIncremental>
    <!--
      Include search order:
        1. $(ProjectDir)          — flat engine headers (Engine.h, Camera.h …)
        2. third_party\glad\…     — <glad/glad.h>
        3. third_party\imgui\…    — <imgui.h> and backends
        4. third_party\stb\       — <stb_image.h>
        5. third_party\glm\       — <glm/glm.hpp>   (populated by setup.sh)
    -->
    <IncludePath>$(ProjectDir);$(SolutionDir)glad\include;$(SolutionDir)third_party\imgui;$(SolutionDir)third_party\imgui\backends;$(SolutionDir)third_party\imgui\examples\libs\glfw\include;$(SolutionDir)third_party\stb;$(SolutionDir)third_party\glm;$(VC_IncludePath);$(WindowsSDK_IncludePath)</IncludePath>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <OutDir>$(SolutionDir)build\bin\Release\</OutDir>
    <IntDir>$(SolutionDir)build\obj\Release\bitEngine\</IntDir>
    <LinkIncremental>false</LinkIncremental>
    <IncludePath>$(ProjectDir);$(SolutionDir)glad\include;$(SolutionDir)third_party\imgui;$(SolutionDir)third_party\imgui\backends;$(SolutionDir)third_party\imgui\examples\libs\glfw\include;$(SolutionDir)third_party\stb;$(SolutionDir)third_party\glm;$(VC_IncludePath);$(WindowsSDK_IncludePath)</IncludePath>
  </PropertyGroup>

  <!-- ── Compiler settings ────────────────────────────────────── -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>Disabled</Optimization>
      <SDLCheck>false</SDLCheck>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <LanguageStandard_C>stdc17</LanguageStandard_C>
      <PreprocessorDefinitions>OBRADEX_DEBUG;_DEBUG;_CONSOLE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <ConformanceMode>true</ConformanceMode>
      <!-- 4100 = unreferenced param (ImGui callbacks); 4505 = unreferenced local fn -->
      <DisableSpecificWarnings>4100;4505</DisableSpecificWarnings>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <!-- Use the pre-built GLFW lib bundled with ImGui for MSVC x64 -->
      <AdditionalLibraryDirectories>$(SolutionDir)third_party\imgui\examples\libs\glfw\lib-vc2010-64;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>glfw3.lib;opengl32.lib;gdi32.lib;user32.lib;shell32.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <!-- Copy Shaders/ folder next to the .exe so they're found at runtime -->
    <PostBuildEvent>
      <Command>
if not exist "$(OutDir)Shaders" mkdir "$(OutDir)Shaders"
xcopy /E /Y /I "$(ProjectDir)Shaders" "$(OutDir)Shaders"
if not exist "$(OutDir)Levels" mkdir "$(OutDir)Levels"
      </Command>
      <Message>Copying shaders to output directory...</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <SDLCheck>false</SDLCheck>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <LanguageStandard_C>stdc17</LanguageStandard_C>
      <PreprocessorDefinitions>OBRADEX_RELEASE;NDEBUG;_CONSOLE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <ConformanceMode>true</ConformanceMode>
      <DisableSpecificWarnings>4100;4505</DisableSpecificWarnings>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalLibraryDirectories>$(SolutionDir)third_party\imgui\examples\libs\glfw\lib-vc2010-64;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>glfw3.lib;opengl32.lib;gdi32.lib;user32.lib;shell32.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <PostBuildEvent>
      <Command>
if not exist "$(OutDir)Shaders" mkdir "$(OutDir)Shaders"
xcopy /E /Y /I "$(ProjectDir)Shaders" "$(OutDir)Shaders"
if not exist "$(OutDir)Levels" mkdir "$(OutDir)Levels"
      </Command>
      <Message>Copying shaders to output directory...</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <!-- ================================================================
       SOURCE FILES  (all flat in bitEngine/ alongside this .vcxproj)
       ================================================================ -->
  <ItemGroup>
    <!-- Entry point -->
    <ClCompile Include="main.cpp" />

    <!-- Core engine -->
    <ClCompile Include="Engine.cpp" />
    <ClCompile Include="Window.cpp" />
    <ClCompile Include="Input.cpp" />
    <ClCompile Include="Timer.cpp" />

    <!-- Renderer -->
    <ClCompile Include="Renderer.cpp" />
    <ClCompile Include="Shader.cpp" />
    <ClCompile Include="Mesh.cpp" />
    <ClCompile Include="Camera.cpp" />
    <ClCompile Include="PostProcess.cpp" />

    <!-- World -->
    <ClCompile Include="World.cpp" />

    <!-- Gameplay -->
    <ClCompile Include="Player.cpp" />
    <ClCompile Include="Interaction.cpp" />

    <!-- Editor UI -->
    <ClCompile Include="EditorUI.cpp" />
    <ClCompile Include="LevelEditor.cpp" />

    <!-- GLAD — C file, needs C compiler not C++ -->
    <ClCompile Include="..\glad\src\glad.c" />

    <!-- Dear ImGui -->
    <ClCompile Include="..\third_party\imgui\imgui.cpp" />
    <ClCompile Include="..\third_party\imgui\imgui_draw.cpp" />
    <ClCompile Include="..\third_party\imgui\imgui_tables.cpp" />
    <ClCompile Include="..\third_party\imgui\imgui_widgets.cpp" />
    <ClCompile Include="..\third_party\imgui\backends\imgui_impl_glfw.cpp" />
    <ClCompile Include="..\third_party\imgui\backends\imgui_impl_opengl3.cpp" />

    <!-- stb_image implementation unit -->
    <ClCompile Include="..\third_party\stb\stb_image_impl.cpp" />
  </ItemGroup>

  <!-- ── HEADERS ────────────────────────────────────────────── -->
  <ItemGroup>
    <ClInclude Include="Engine.h" />
    <ClInclude Include="Window.h" />
    <ClInclude Include="Input.h" />
    <ClInclude Include="Timer.h" />
    <ClInclude Include="Renderer.h" />
    <ClInclude Include="Shader.h" />
    <ClInclude Include="Mesh.h" />
    <ClInclude Include="Camera.h" />
    <ClInclude Include="PostProcess.h" />
    <ClInclude Include="World.h" />
    <ClInclude Include="Player.h" />
    <ClInclude Include="Interaction.h" />
    <ClInclude Include="EditorUI.h" />
    <ClInclude Include="LevelEditor.h" />
  </ItemGroup>

  <!-- ── SHADERS (visible in Solution Explorer) ────────────── -->
  <ItemGroup>
    <None Include="Shaders\world.vert" />
    <None Include="Shaders\world.frag" />
  </ItemGroup>

  <!-- ── OTHER ─────────────────────────────────────────────── -->
  <ItemGroup>
    <None Include="..\CMakeLists.txt" />
    <None Include="..\setup.sh" />
    <None Include="..\README.md" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets" />
</Project>
